    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.local/share/dippy/bin/dippy-hook"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/pre_push_gate.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# sounds.sh: soundsh/minecraft-villager-hmm\nafplay \"__HOME__/.claude/sounds/soundsh--minecraft-villager-hmm.mp3\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# sounds.sh: soundsh/minecraft-hurt\nafplay \"__HOME__/.claude/sounds/soundsh--minecraft-hurt.mp3\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "# sounds.sh: soundsh/minecraft-eating\nafplay \"__HOME__/.claude/sounds/soundsh--minecraft-eating.mp3\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/file_checker.py"
          },
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/tdd_enforcer.py"
          }
        ]
      },
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/pre_compact.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/discovery_scan.py"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/post_compact_restore.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __HOME__/.claude/devflow/hooks/spec_stop_guard.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccline",
    "padding": 0
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "firebase@firebase": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "firebase": {
      "source": {
        "source": "github",
        "repo": "firebase/agent-skills"
      }
    }
  },
  "language": "Português Brasileiro",
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "mixpanel": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.mixpanel.com/mcp"
      ]
    }
  },
  "linear": {
    "apiKey": "__LINEAR_API_KEY__"
  },
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "8000"
  },
  "contextCompactionThreshold": 80,
  "model": "sonnet"
}